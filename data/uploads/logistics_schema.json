{
  "tables": [
    {
      "table_name": "MST_PRODUCT",
      "table_type": "master_table",
      "description": "상품 마스터 - 물류센터에서 취급하는 전체 상품의 기본 속성 및 보관 조건 정의",
      "columns": [
        { "name": "PRODUCT_NO",    "type": "VARCHAR", "pk": true,  "description": "상품 고유 번호" },
        { "name": "PRODUCT_NAME",  "type": "VARCHAR", "pk": false, "description": "상품명" },
        { "name": "CATEGORY_CD",   "type": "VARCHAR", "pk": false, "description": "상품 카테고리 코드" },
        { "name": "WEIGHT_KG",     "type": "NUMBER",  "pk": false, "description": "상품 무게 (kg)" },
        { "name": "VOLUME_CBM",    "type": "NUMBER",  "pk": false, "description": "상품 부피 (CBM)" },
        { "name": "TEMP_COND",     "type": "VARCHAR", "pk": false, "description": "보관 온도 조건 (ROOM/COOL/FROZEN)" },
        { "name": "SUPPLIER_CD",   "type": "VARCHAR", "pk": false, "description": "공급업체 코드 (FK → MST_SUPPLIER)" },
        { "name": "STATUS",        "type": "VARCHAR", "pk": false, "description": "상품 상태 (ACTIVE/INACTIVE)" }
      ]
    },
    {
      "table_name": "MST_SUPPLIER",
      "table_type": "master_table",
      "description": "공급업체 마스터 - 상품을 납품하는 공급업체 기본 정보 및 협력사 등급",
      "columns": [
        { "name": "SUPPLIER_CD",    "type": "VARCHAR", "pk": true,  "description": "공급업체 코드" },
        { "name": "SUPPLIER_NAME",  "type": "VARCHAR", "pk": false, "description": "공급업체명" },
        { "name": "REGION",         "type": "VARCHAR", "pk": false, "description": "소재 지역" },
        { "name": "LEAD_TIME_DAY",  "type": "NUMBER",  "pk": false, "description": "평균 납기 리드타임 (일)" },
        { "name": "RATING",         "type": "VARCHAR", "pk": false, "description": "협력사 등급 (A/B/C)" },
        { "name": "STATUS",         "type": "VARCHAR", "pk": false, "description": "계약 상태 (ACTIVE/INACTIVE)" }
      ]
    },
    {
      "table_name": "MST_WAREHOUSE",
      "table_type": "master_table",
      "description": "창고/물류센터 마스터 - 보관 용량, 온도 구역, 운영 상태 관리",
      "columns": [
        { "name": "WAREHOUSE_CD",    "type": "VARCHAR", "pk": true,  "description": "창고 코드" },
        { "name": "WAREHOUSE_NAME",  "type": "VARCHAR", "pk": false, "description": "창고명" },
        { "name": "REGION",          "type": "VARCHAR", "pk": false, "description": "창고 소재 지역" },
        { "name": "CAPACITY_CBM",    "type": "NUMBER",  "pk": false, "description": "최대 보관 용량 (CBM)" },
        { "name": "TEMP_ZONE",       "type": "VARCHAR", "pk": false, "description": "온도 구역 (ROOM/COOL/FROZEN/MIXED)" },
        { "name": "STATUS",          "type": "VARCHAR", "pk": false, "description": "운영 상태 (ACTIVE/INACTIVE)" }
      ]
    },
    {
      "table_name": "MST_CARRIER",
      "table_type": "master_table",
      "description": "운송사 마스터 - 배송을 담당하는 운송 업체 및 SLA 정보",
      "columns": [
        { "name": "CARRIER_CD",        "type": "VARCHAR", "pk": true,  "description": "운송사 코드" },
        { "name": "CARRIER_NAME",      "type": "VARCHAR", "pk": false, "description": "운송사명" },
        { "name": "CARRIER_TYPE",      "type": "VARCHAR", "pk": false, "description": "운송 유형 (TRUCK/COURIER/FREIGHT)" },
        { "name": "COVERAGE_REGION",   "type": "VARCHAR", "pk": false, "description": "서비스 가능 지역" },
        { "name": "SLA_DAY",           "type": "NUMBER",  "pk": false, "description": "배송 SLA 기준 일수" },
        { "name": "RATING",            "type": "VARCHAR", "pk": false, "description": "운송사 등급 (A/B/C)" },
        { "name": "STATUS",            "type": "VARCHAR", "pk": false, "description": "계약 상태 (ACTIVE/INACTIVE)" }
      ]
    },
    {
      "table_name": "MST_ROUTE",
      "table_type": "master_table",
      "description": "배송 경로 마스터 - 출발 창고/도착 지역별 경로 코드, 담당 운송사, 예상 소요일 정의",
      "columns": [
        { "name": "ROUTE_CD",             "type": "VARCHAR", "pk": true,  "description": "경로 코드" },
        { "name": "ORIGIN_WAREHOUSE_CD",  "type": "VARCHAR", "pk": false, "description": "출발 창고 코드 (FK → MST_WAREHOUSE)" },
        { "name": "DEST_REGION",          "type": "VARCHAR", "pk": false, "description": "도착 지역" },
        { "name": "CARRIER_CD",           "type": "VARCHAR", "pk": false, "description": "담당 운송사 코드 (FK → MST_CARRIER)" },
        { "name": "EST_TRANSIT_DAY",      "type": "NUMBER",  "pk": false, "description": "예상 운송 소요 일수" },
        { "name": "ROUTE_STATUS",         "type": "VARCHAR", "pk": false, "description": "경로 상태 (ACTIVE/INACTIVE)" }
      ]
    },
    {
      "table_name": "FACT_INBOUND",
      "table_type": "fact_table",
      "description": "입고 실적 - 공급업체로부터 창고로의 입고 이력, 수량·금액·불량 수량 기록",
      "columns": [
        { "name": "INBOUND_NO",    "type": "VARCHAR", "pk": true,  "description": "입고 번호" },
        { "name": "INBOUND_DT",    "type": "DATE",    "pk": false, "description": "입고 일자" },
        { "name": "PRODUCT_NO",    "type": "VARCHAR", "pk": false, "description": "상품 번호 (FK → MST_PRODUCT)" },
        { "name": "SUPPLIER_CD",   "type": "VARCHAR", "pk": false, "description": "공급업체 코드 (FK → MST_SUPPLIER)" },
        { "name": "WAREHOUSE_CD",  "type": "VARCHAR", "pk": false, "description": "입고 창고 코드 (FK → MST_WAREHOUSE)" },
        { "name": "INBOUND_QTY",   "type": "NUMBER",  "pk": false, "description": "입고 수량" },
        { "name": "DEFECT_QTY",    "type": "NUMBER",  "pk": false, "description": "불량 수량" },
        { "name": "INBOUND_AMT",   "type": "NUMBER",  "pk": false, "description": "입고 금액 (원)" },
        { "name": "STATUS",        "type": "VARCHAR", "pk": false, "description": "처리 상태 (RECEIVED/INSPECTED/PUTAWAY)" }
      ]
    },
    {
      "table_name": "FACT_OUTBOUND",
      "table_type": "fact_table",
      "description": "출고 실적 - 창고에서 고객으로의 출고 및 배송 지시 이력",
      "columns": [
        { "name": "OUTBOUND_NO",    "type": "VARCHAR", "pk": true,  "description": "출고 번호" },
        { "name": "OUTBOUND_DT",    "type": "DATE",    "pk": false, "description": "출고 일자" },
        { "name": "PRODUCT_NO",     "type": "VARCHAR", "pk": false, "description": "상품 번호 (FK → MST_PRODUCT)" },
        { "name": "WAREHOUSE_CD",   "type": "VARCHAR", "pk": false, "description": "출고 창고 코드 (FK → MST_WAREHOUSE)" },
        { "name": "CARRIER_CD",     "type": "VARCHAR", "pk": false, "description": "운송사 코드 (FK → MST_CARRIER)" },
        { "name": "ROUTE_CD",       "type": "VARCHAR", "pk": false, "description": "배송 경로 코드 (FK → MST_ROUTE)" },
        { "name": "OUTBOUND_QTY",   "type": "NUMBER",  "pk": false, "description": "출고 수량" },
        { "name": "OUTBOUND_AMT",   "type": "NUMBER",  "pk": false, "description": "출고 금액 (원)" },
        { "name": "PROMISED_DT",    "type": "DATE",    "pk": false, "description": "약속 배송 일자" },
        { "name": "STATUS",         "type": "VARCHAR", "pk": false, "description": "출고 상태 (PICKED/PACKED/SHIPPED/DELIVERED)" }
      ]
    },
    {
      "table_name": "FACT_INVENTORY_SNAPSHOT",
      "table_type": "fact_table",
      "description": "재고 스냅샷 - 일별 상품별/창고별 재고 수량, 가용재고, 입출고 집계",
      "columns": [
        { "name": "SNAPSHOT_DT",    "type": "DATE",    "pk": false, "description": "기준 일자" },
        { "name": "PRODUCT_NO",     "type": "VARCHAR", "pk": false, "description": "상품 번호 (FK → MST_PRODUCT)" },
        { "name": "WAREHOUSE_CD",   "type": "VARCHAR", "pk": false, "description": "창고 코드 (FK → MST_WAREHOUSE)" },
        { "name": "STOCK_QTY",      "type": "NUMBER",  "pk": false, "description": "재고 수량" },
        { "name": "AVAILABLE_QTY",  "type": "NUMBER",  "pk": false, "description": "가용 재고 수량 (예약 수량 제외)" },
        { "name": "RESERVED_QTY",   "type": "NUMBER",  "pk": false, "description": "예약 수량" },
        { "name": "STOCKOUT_YN",    "type": "VARCHAR", "pk": false, "description": "품절 여부 (Y/N)" },
        { "name": "INBOUND_QTY",    "type": "NUMBER",  "pk": false, "description": "당일 입고 수량" },
        { "name": "OUTBOUND_QTY",   "type": "NUMBER",  "pk": false, "description": "당일 출고 수량" }
      ]
    },
    {
      "table_name": "FACT_DELIVERY_TRACKING",
      "table_type": "fact_table",
      "description": "배송 추적 - 출고건별 운송장 기준 배송 상태, 실제 도착일, 지연 일수 기록",
      "columns": [
        { "name": "TRACKING_NO",          "type": "VARCHAR", "pk": true,  "description": "운송장 번호" },
        { "name": "OUTBOUND_NO",          "type": "VARCHAR", "pk": false, "description": "출고 번호 (FK → FACT_OUTBOUND)" },
        { "name": "CARRIER_CD",           "type": "VARCHAR", "pk": false, "description": "운송사 코드 (FK → MST_CARRIER)" },
        { "name": "ROUTE_CD",             "type": "VARCHAR", "pk": false, "description": "배송 경로 코드 (FK → MST_ROUTE)" },
        { "name": "PICKUP_DT",            "type": "DATE",    "pk": false, "description": "집하 일자" },
        { "name": "ACTUAL_DELIVERY_DT",   "type": "DATE",    "pk": false, "description": "실제 배송 완료 일자" },
        { "name": "DELAY_DAY",            "type": "NUMBER",  "pk": false, "description": "배송 지연 일수 (음수 = 조기 도착)" },
        { "name": "DELIVERY_STATUS",      "type": "VARCHAR", "pk": false, "description": "배송 상태 (IN_TRANSIT/DELIVERED/FAILED/RETURNED)" },
        { "name": "FAIL_REASON",          "type": "VARCHAR", "pk": false, "description": "배송 실패 사유" }
      ]
    }
  ],
  "relationships": [
    {
      "from": "MST_PRODUCT",             "to": "MST_SUPPLIER",
      "join_key": "SUPPLIER_CD",          "relation": "JOIN"
    },
    {
      "from": "MST_ROUTE",               "to": "MST_WAREHOUSE",
      "join_key": "ORIGIN_WAREHOUSE_CD", "relation": "JOIN"
    },
    {
      "from": "MST_ROUTE",               "to": "MST_CARRIER",
      "join_key": "CARRIER_CD",           "relation": "JOIN"
    },
    {
      "from": "FACT_INBOUND",            "to": "MST_PRODUCT",
      "join_key": "PRODUCT_NO",           "relation": "JOIN"
    },
    {
      "from": "FACT_INBOUND",            "to": "MST_SUPPLIER",
      "join_key": "SUPPLIER_CD",          "relation": "JOIN"
    },
    {
      "from": "FACT_INBOUND",            "to": "MST_WAREHOUSE",
      "join_key": "WAREHOUSE_CD",         "relation": "JOIN"
    },
    {
      "from": "FACT_OUTBOUND",           "to": "MST_PRODUCT",
      "join_key": "PRODUCT_NO",           "relation": "JOIN"
    },
    {
      "from": "FACT_OUTBOUND",           "to": "MST_WAREHOUSE",
      "join_key": "WAREHOUSE_CD",         "relation": "JOIN"
    },
    {
      "from": "FACT_OUTBOUND",           "to": "MST_CARRIER",
      "join_key": "CARRIER_CD",           "relation": "JOIN"
    },
    {
      "from": "FACT_OUTBOUND",           "to": "MST_ROUTE",
      "join_key": "ROUTE_CD",             "relation": "JOIN"
    },
    {
      "from": "FACT_INVENTORY_SNAPSHOT", "to": "MST_PRODUCT",
      "join_key": "PRODUCT_NO",           "relation": "JOIN"
    },
    {
      "from": "FACT_INVENTORY_SNAPSHOT", "to": "MST_WAREHOUSE",
      "join_key": "WAREHOUSE_CD",         "relation": "JOIN"
    },
    {
      "from": "FACT_DELIVERY_TRACKING",  "to": "FACT_OUTBOUND",
      "join_key": "OUTBOUND_NO",          "relation": "JOIN"
    },
    {
      "from": "FACT_DELIVERY_TRACKING",  "to": "MST_CARRIER",
      "join_key": "CARRIER_CD",           "relation": "JOIN"
    },
    {
      "from": "FACT_DELIVERY_TRACKING",  "to": "MST_ROUTE",
      "join_key": "ROUTE_CD",             "relation": "JOIN"
    }
  ]
}
