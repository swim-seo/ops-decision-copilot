# secrets.toml 설정 예시 (이 파일은 GitHub에 커밋됩니다)
#
# ── 로컬 개발 ─────────────────────────────────────────────────────────────────
# 이 파일을 복사해 .streamlit/secrets.toml 을 만들고 실제 키를 입력하세요.
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# ── Streamlit Cloud 배포 ──────────────────────────────────────────────────────
# 앱 대시보드 → Settings → Secrets 에 아래 내용을 그대로 붙여넣고
# 값만 실제 키로 교체하세요.

ANTHROPIC_API_KEY = "sk-ant-..."

# Supabase PostgreSQL (선택사항 — 없으면 CSV 모드로 동작)
SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_KEY = "your_supabase_anon_or_service_key"
